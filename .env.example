# PDM Platform - Environment Configuration
# Copy this to .env and customize for your deployment

# Server
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# Security
SESSION_SECRET=generate-a-random-64-char-string-here
ALLOWED_ORIGINS=http://localhost:4000,http://your-domain.com

# Email (optional - for notification emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pdm-platform.com

# Database (optional - defaults to SQLite)
# DATABASE_URL=sqlite:///app/database/pdm.db
