<div class="flex items-center justify-between mb-6">
  <div>
    <h2 class="text-xl font-bold text-surface-800 dark:text-white">Notifications</h2>
    <p class="text-sm text-surface-500 dark:text-surface-400 mt-0.5"><%= unreadNotifCount %> unread notifications</p>
  </div>
  <% if (unreadNotifCount > 0) { %>
    <form method="POST" action="/notifications/read-all"><button type="submit" class="text-sm text-primary-600 hover:text-primary-800 dark:text-primary-400 font-medium"><i class="fas fa-check-double mr-1"></i>Mark All Read</button></form>
  <% } %>
</div>

<div class="space-y-2">
  <% if (notifications.length === 0) { %>
    <div class="text-center py-12 text-surface-400"><i class="fas fa-bell-slash text-3xl mb-2"></i><p>No notifications</p></div>
  <% } else { %>
    <% notifications.forEach(n => { %>
      <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 p-4 flex items-start gap-4 hover:shadow-sm transition-shadow <%= !n.is_read ? 'border-l-4 border-l-primary-500' : '' %>">
        <div class="w-8 h-8 rounded-full <%= !n.is_read ? 'bg-primary-100 dark:bg-primary-900/30 text-primary-600' : 'bg-surface-100 dark:bg-surface-700 text-surface-400' %> flex items-center justify-center shrink-0">
          <i class="fas <%= n.type === 'slip_approved' ? 'fa-check-circle' : n.type === 'slip_rejected' ? 'fa-xmark-circle' : n.type === 'slip_submitted' ? 'fa-file-circle-plus' : n.type === 'slip_changes_requested' ? 'fa-pen-to-square' : n.type === 'invoice_created' ? 'fa-file-invoice' : n.type === 'invoice_reconciled' ? 'fa-scale-balanced' : n.type === 'invoice_paid' ? 'fa-sack-dollar' : n.type === 'payment_received' ? 'fa-coins' : n.type === 'user_created' ? 'fa-user-plus' : n.type === 'role_updated' ? 'fa-user-gear' : 'fa-bell' %>"></i>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between gap-2">
            <div>
              <p class="text-sm font-medium text-surface-800 dark:text-surface-200"><%= n.title %></p>
              <p class="text-xs text-surface-500 mt-0.5"><%= n.message || '' %></p>
            </div>
            <span class="text-xs text-surface-400 whitespace-nowrap"><%= new Date(n.created_at).toLocaleDateString() %></span>
          </div>
          <div class="flex items-center gap-3 mt-2">
            <% if (n.link) { %><a href="<%= n.link %>" class="text-xs text-primary-600 hover:text-primary-800 dark:text-primary-400 font-medium"><i class="fas fa-eye mr-1"></i>View</a><% } %>
            <% if (!n.is_read) { %>
              <form method="POST" action="/notifications/read/<%= n.id %>" class="inline">
                <button type="submit" class="text-xs text-surface-400 hover:text-surface-600"><i class="fas fa-check mr-1"></i>Mark Read</button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>
