<div class="mb-6">
  <a href="/dashboard" class="text-sm text-primary-600 dark:text-primary-400 hover:underline mb-2 inline-block"><i class="fas fa-arrow-left mr-1"></i>Back to Dashboard</a>
  <h2 class="text-xl font-bold text-surface-800 dark:text-white">Create Invoice</h2>
  <p class="text-sm text-surface-500 dark:text-surface-400 mt-0.5">Generate invoice from approved slip</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2">
    <form method="POST" action="/invoices/create/<%= slip.id %>" class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 p-6 space-y-6">
      <h3 class="font-semibold text-surface-800 dark:text-white">Invoice Details</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Hours to Bill</label>
          <input type="number" step="0.5" name="hours" value="<%= slip.total_hours %>" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Rate per Hour ($)</label>
          <input type="number" step="0.01" name="rate" value="<%= slip.rate_per_hour %>" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Tax Rate (%)</label>
          <input type="number" step="0.01" name="tax_rate" value="6.25" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none">
        </div>
        <div>
          <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Payment Terms</label>
          <select name="payment_terms" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none">
            <option value="Net 30">Net 30</option>
            <option value="Net 15">Net 15</option>
            <option value="Net 45">Net 45</option>
            <option value="Due on Receipt">Due on Receipt</option>
          </select>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Notes</label>
          <textarea name="notes" rows="3" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none" placeholder="Invoice notes..."></textarea>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button type="submit" class="bg-primary-600 hover:bg-primary-700 text-white font-medium px-6 py-2.5 rounded-lg transition-colors text-sm"><i class="fas fa-file-invoice-dollar mr-1"></i>Generate Invoice</button>
        <a href="/dashboard" class="text-surface-600 dark:text-surface-400 hover:text-surface-800 px-4 py-2.5 text-sm">Cancel</a>
      </div>
    </form>
  </div>

  <!-- Slip Info Sidebar -->
  <div>
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 p-6">
      <h3 class="font-semibold text-surface-800 dark:text-white text-sm mb-4">Slip Information</h3>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between"><dt class="text-surface-400">Slip</dt><dd class="text-surface-700 dark:text-surface-300 font-medium"><%= slip.slip_number %></dd></div>
        <div class="flex justify-between"><dt class="text-surface-400">Project</dt><dd class="text-surface-700 dark:text-surface-300"><%= slip.project_number %></dd></div>
        <div class="flex justify-between"><dt class="text-surface-400">Officer</dt><dd class="text-surface-700 dark:text-surface-300"><%= slip.officer_name %></dd></div>
        <div class="flex justify-between"><dt class="text-surface-400">Hours</dt><dd class="text-surface-700 dark:text-surface-300"><%= slip.total_hours %></dd></div>
        <div class="flex justify-between"><dt class="text-surface-400">Rate</dt><dd class="text-surface-700 dark:text-surface-300">$<%= Number(slip.rate_per_hour).toFixed(2) %>/hr</dd></div>
        <div class="flex justify-between border-t border-surface-200 dark:border-surface-700 pt-3 mt-3"><dt class="text-surface-400 font-medium">Est. Subtotal</dt><dd class="text-surface-800 dark:text-white font-bold">$<%= (slip.total_hours * slip.rate_per_hour).toFixed(2) %></dd></div>
        <div class="flex justify-between"><dt class="text-surface-400">Location</dt><dd class="text-surface-700 dark:text-surface-300"><%= slip.location_details || 'N/A' %></dd></div>
        <div class="flex justify-between"><dt class="text-surface-400">Foreman</dt><dd class="text-surface-700 dark:text-surface-300"><%= slip.foreman_name %></dd></div>
        <div class="flex justify-between"><dt class="text-surface-400">Vendor</dt><dd class="text-surface-700 dark:text-surface-300"><%= slip.org_name %></dd></div>
      </dl>
    </div>
  </div>
</div>
