<div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6">
  <div>
    <h2 class="text-xl font-bold text-surface-800 dark:text-white">Invoices</h2>
    <p class="text-sm text-surface-500 dark:text-surface-400 mt-0.5">Manage invoices from approved police detail slips</p>
  </div>
</div>

<div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 p-4 mb-6">
  <form method="GET" action="/invoices" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
    <div>
      <label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">Search</label>
      <div class="relative">
        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-surface-400 text-xs"></i>
        <input type="text" name="search" value="<%= query.search || '' %>" class="w-full pl-8 pr-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none" placeholder="Invoice #, Slip #...">
      </div>
    </div>
    <div>
      <label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">Status</label>
      <select name="status" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none">
        <option value="">All Statuses</option>
        <% ['draft','submitted','under_review','reconciled','disputed','paid','archived'].forEach(s => { %>
          <option value="<%= s %>" <%= query.status === s ? 'selected' : '' %>><%= s.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) %></option>
        <% }) %>
      </select>
    </div>
    <div><label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">From</label><input type="date" name="date_from" value="<%= query.date_from || '' %>" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"></div>
    <div><label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">To</label><div class="flex gap-2"><input type="date" name="date_to" value="<%= query.date_to || '' %>" class="flex-1 px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"><button type="submit" class="px-3 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg text-sm"><i class="fas fa-filter"></i></button><a href="/invoices" class="px-3 py-2 bg-surface-200 dark:bg-surface-600 hover:bg-surface-300 text-surface-600 rounded-lg text-sm"><i class="fas fa-times"></i></a></div></div>
  </form>
</div>

<div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-surface-50 dark:bg-surface-800/50 text-left text-xs text-surface-500 uppercase tracking-wider">
          <th class="px-5 py-3 font-medium">Invoice #</th>
          <th class="px-5 py-3 font-medium">Slip #</th>
          <th class="px-5 py-3 font-medium">Organization</th>
          <th class="px-5 py-3 font-medium">Subtotal</th>
          <th class="px-5 py-3 font-medium">Total</th>
          <th class="px-5 py-3 font-medium">Status</th>
          <th class="px-5 py-3 font-medium">Created</th>
          <th class="px-5 py-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-surface-100 dark:divide-surface-700">
        <% if (invoices.length === 0) { %>
          <tr><td colspan="8" class="px-5 py-12 text-center text-surface-400"><i class="fas fa-file-invoice-dollar text-2xl mb-2"></i><p>No invoices found</p></td></tr>
        <% } else { %>
          <% invoices.forEach(inv => { %>
            <tr class="hover:bg-surface-50 dark:hover:bg-surface-700/30 transition-colors">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-200"><%= inv.invoice_number %></td>
              <td class="px-5 py-3.5 text-surface-600"><%= inv.slip_number %></td>
              <td class="px-5 py-3.5 text-surface-600"><%= inv.org_name || 'N/A' %></td>
              <td class="px-5 py-3.5 text-surface-600">$<%= Number(inv.subtotal).toFixed(2) %></td>
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-200">$<%= Number(inv.grand_total).toFixed(2) %></td>
              <td class="px-5 py-3.5"><span class="badge-<%= inv.status %>"><%= inv.status.replace('_', ' ') %></span></td>
              <td class="px-5 py-3.5 text-surface-500 text-xs"><%= new Date(inv.created_at).toLocaleDateString() %></td>
              <td class="px-5 py-3.5"><a href="/invoices/view/<%= inv.id %>" class="text-primary-600 hover:text-primary-800 dark:text-primary-400 text-xs font-medium"><i class="fas fa-eye mr-1"></i>View</a></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
