<h2 class="text-xl font-bold text-surface-800 dark:text-white mb-1">Organizations</h2>
<p class="text-sm text-surface-500 dark:text-surface-400 mb-6">Manage utility companies and vendors</p>

<div class="mb-6">
  <button onclick="document.getElementById('createOrgModal').classList.remove('hidden')" class="bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors inline-flex items-center gap-2"><i class="fas fa-plus"></i>Add Organization</button>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
  <% orgs.forEach(o => { %>
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 p-5">
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-primary-100 dark:bg-primary-900/20 flex items-center justify-center"><i class="fas fa-building text-primary-600 dark:text-primary-400"></i></div>
          <div><h3 class="font-medium text-surface-800 dark:text-white"><%= o.name %></h3><span class="text-xs <%= o.type === 'utility' ? 'text-blue-600' : 'text-violet-600' %>"><i class="fas fa-circle text-[6px] mr-1"></i><%= o.type %></span></div>
        </div>
        <button onclick="editOrg(<%= o.id %>,'<%= o.name %>','<%= o.type %>','<%= o.address || '' %>','<%= o.phone || '' %>','<%= o.email || '' %>',<%= o.is_active %>)" class="text-xs text-primary-600 hover:text-primary-800"><i class="fas fa-pen"></i></button>
      </div>
      <div class="text-xs text-surface-400 space-y-1"><p><%= o.address || 'No address' %></p><p><%= o.phone || 'No phone' %></p><p><%= o.email || 'No email' %></p></div>
      <div class="mt-3 pt-3 border-t border-surface-100 dark:border-surface-700 flex justify-between text-xs"><span class="text-surface-400"><%= o.is_active ? 'Active' : 'Inactive' %></span></div>
    </div>
  <% }) %>
</div>

<!-- Create Modal -->
<div id="createOrgModal" class="fixed inset-0 z-50 bg-black/50 flex items-center justify-center hidden" onclick="if(event.target===this)this.classList.add('hidden')">
  <div class="bg-white dark:bg-surface-800 rounded-2xl shadow-2xl w-full max-w-lg mx-4 p-6">
    <div class="flex items-center justify-between mb-4"><h3 class="text-lg font-bold text-surface-800 dark:text-white">Add Organization</h3><button onclick="document.getElementById('createOrgModal').classList.add('hidden')" class="text-surface-400 hover:text-surface-600"><i class="fas fa-times"></i></button></div>
    <form method="POST" action="/admin/organizations/create" class="space-y-4">
      <div class="grid grid-cols-2 gap-3">
        <div><label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1">Name</label><input type="text" name="name" required class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"></div>
        <div><label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1">Type</label><select name="type" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"><option value="utility">Utility</option><option value="vendor">Vendor</option></select></div>
        <div class="col-span-2"><label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1">Address</label><input type="text" name="address" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"></div>
        <div><label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1">Phone</label><input type="text" name="phone" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"></div>
        <div><label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1">Email</label><input type="email" name="email" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"></div>
      </div>
      <div class="flex gap-3 pt-2"><button type="submit" class="flex-1 bg-primary-600 hover:bg-primary-700 text-white font-medium px-4 py-2.5 rounded-lg text-sm">Create</button><button type="button" onclick="document.getElementById('createOrgModal').classList.add('hidden')" class="px-4 py-2.5 text-sm text-surface-600 hover:text-surface-800">Cancel</button></div>
    </form>
  </div>
</div>

<!-- Edit Modal -->
<div id="editOrgModal" class="fixed inset-0 z-50 bg-black/50 flex items-center justify-center hidden" onclick="if(event.target===this)this.classList.add('hidden')">
  <div class="bg-white dark:bg-surface-800 rounded-2xl shadow-2xl w-full max-w-lg mx-4 p-6">
    <div class="flex items-center justify-between mb-4"><h3 class="text-lg font-bold text-surface-800 dark:text-white">Edit Organization</h3><button onclick="document.getElementById('editOrgModal').classList.add('hidden')" class="text-surface-400 hover:text-surface-600"><i class="fas fa-times"></i></button></div>
    <form method="POST" id="editOrgForm" class="space-y-4">
      <div class="grid grid-cols-2 gap-3">
        <div><label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1">Name</label><input type="text" name="name" id="edit_org_name" required class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"></div>
        <div><label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1">Type</label><select name="type" id="edit_org_type" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"><option value="utility">Utility</option><option value="vendor">Vendor</option></select></div>
        <div class="col-span-2"><label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1">Address</label><input type="text" name="address" id="edit_org_address" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"></div>
        <div><label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1">Phone</label><input type="text" name="phone" id="edit_org_phone" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"></div>
        <div><label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1">Email</label><input type="email" name="email" id="edit_org_email" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"></div>
        <div><label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1">Active</label><select name="is_active" id="edit_org_active" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"><option value="1">Active</option><option value="0">Inactive</option></select></div>
      </div>
      <div class="flex gap-3 pt-2"><button type="submit" class="flex-1 bg-primary-600 hover:bg-primary-700 text-white font-medium px-4 py-2.5 rounded-lg text-sm">Update</button><button type="button" onclick="document.getElementById('editOrgModal').classList.add('hidden')" class="px-4 py-2.5 text-sm text-surface-600 hover:text-surface-800">Cancel</button></div>
    </form>
  </div>
</div>

<script>
function editOrg(id, name, type, address, phone, email, active) {
  document.getElementById('edit_org_name').value = name;
  document.getElementById('edit_org_type').value = type;
  document.getElementById('edit_org_address').value = address;
  document.getElementById('edit_org_phone').value = phone;
  document.getElementById('edit_org_email').value = email;
  document.getElementById('edit_org_active').value = active;
  document.getElementById('editOrgForm').action = '/admin/organizations/edit/' + id;
  document.getElementById('editOrgModal').classList.remove('hidden');
}
</script>
