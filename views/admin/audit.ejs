<h2 class="text-xl font-bold text-surface-800 dark:text-white mb-1">Audit Log</h2>
<p class="text-sm text-surface-500 dark:text-surface-400 mb-6">Immutable record of all system actions</p>

<div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 p-4 mb-6">
  <form method="GET" action="/admin/audit" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
    <div><label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">Action</label><select name="action" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"><option value="">All</option><% ['LOGIN','LOGOUT','CREATE','SUBMIT','APPROVE','REJECT','EDIT','RECONCILE','PAY','ARCHIVE','CREATE_USER','EDIT_USER','CREATE_ORG'].forEach(a => { %><option value="<%= a %>" <%= query.action === a ? 'selected' : '' %>><%= a %></option><% }) %></select></div>
    <div><label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">Entity</label><select name="entity_type" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"><option value="">All</option><% ['slip','invoice','user','organization'].forEach(e => { %><option value="<%= e %>" <%= query.entity_type === e ? 'selected' : '' %>><%= e %></option><% }) %></select></div>
    <div><label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">User ID</label><input type="number" name="user_id" value="<%= query.user_id || '' %>" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"></div>
    <div><label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">From</label><input type="date" name="date_from" value="<%= query.date_from || '' %>" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"></div>
    <div><label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">To</label><input type="date" name="date_to" value="<%= query.date_to || '' %>" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none"></div>
    <div class="flex items-end gap-2"><button type="submit" class="flex-1 px-3 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg text-sm"><i class="fas fa-search mr-1"></i>Search</button><a href="/admin/audit" class="px-3 py-2 bg-surface-200 dark:bg-surface-600 hover:bg-surface-300 dark:hover:bg-surface-500 text-surface-600 dark:text-surface-300 rounded-lg text-sm"><i class="fas fa-times"></i></a></div>
  </form>
</div>

<div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead><tr class="bg-surface-50 dark:bg-surface-800/50 text-left text-xs text-surface-500 uppercase tracking-wider"><th class="px-4 py-3 font-medium">Timestamp</th><th class="px-4 py-3 font-medium">User</th><th class="px-4 py-3 font-medium">Role</th><th class="px-4 py-3 font-medium">Action</th><th class="px-4 py-3 font-medium">Entity</th><th class="px-4 py-3 font-medium">Entity ID</th><th class="px-4 py-3 font-medium">IP</th></tr></thead>
      <tbody class="divide-y divide-surface-100 dark:divide-surface-700">
        <% if (logs.length === 0) { %><tr><td colspan="7" class="px-4 py-12 text-center text-surface-400">No audit logs found</td></tr><% } %>
        <% logs.forEach(log => { %>
          <tr class="hover:bg-surface-50 dark:hover:bg-surface-700/30 transition-colors text-xs">
            <td class="px-4 py-3 text-surface-500 whitespace-nowrap"><%= new Date(log.created_at + 'Z').toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit', hour12: true }) %> IST</td>
            <td class="px-4 py-3 text-surface-700 dark:text-surface-300 font-medium"><%= log.username %></td>
            <td class="px-4 py-3"><span class="text-xs px-2 py-0.5 rounded-full bg-surface-100 dark:bg-surface-700 text-surface-600"><%= log.role %></span></td>
            <td class="px-4 py-3"><span class="text-xs font-medium px-2 py-0.5 rounded-full <%= log.action === 'LOGIN' ? 'bg-green-100 text-green-700' : log.action === 'APPROVE' || log.action === 'PAY' ? 'bg-emerald-100 text-emerald-700' : log.action === 'REJECT' || log.action === 'DISPUTE' ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700' %>"><%= log.action %></span></td>
            <td class="px-4 py-3 text-surface-600"><%= log.entity_type %></td>
            <td class="px-4 py-3 text-surface-600"><%= log.entity_id || '-' %></td>
            <td class="px-4 py-3 text-surface-400 font-mono"><%= log.ip_address || '-' %></td>
          </tr>
          <% if (log.before_state || log.after_state) { %>
            <tr class="bg-surface-50/50 dark:bg-surface-700/20"><td colspan="7" class="px-8 py-2 text-xs text-surface-400 font-mono whitespace-pre-wrap"><% if (log.before_state) { %><span class="text-red-500">Before:</span> <%= JSON.stringify(JSON.parse(log.before_state)) %><% } %><% if (log.before_state && log.after_state) { %> → <% } %><% if (log.after_state) { %><span class="text-green-500">After:</span> <%= JSON.stringify(JSON.parse(log.after_state)) %><% } %></td></tr>
          <% } %>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
