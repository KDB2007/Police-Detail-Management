<h2 class="text-xl font-bold text-surface-800 dark:text-white mb-1">System Settings</h2>
<p class="text-sm text-surface-500 dark:text-surface-400 mb-6">Manage roles, permissions, and system configuration</p>

<div class="grid grid-cols-1 gap-6">
  <% roles.forEach(role => { %>
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 p-6">
      <h3 class="font-semibold text-surface-800 dark:text-white text-lg mb-1"><%= role.name.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) %></h3>
      <p class="text-sm text-surface-500 mb-4"><%= role.description %></p>
      <form method="POST" action="/admin/settings/roles/<%= role.id %>">
        <div class="mb-4">
          <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-2">Permissions</label>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
            <% const currentPerms = JSON.parse(role.permissions || '[]'); %>
            <% const allPerms = ['*','slip:create','slip:edit','slip:submit','slip:view','slip:review','slip:approve','slip:reject','attachment:upload','invoice:create','invoice:edit','invoice:submit','invoice:view','invoice:reconcile','invoice:pay','invoice:archive','report:view','audit:view','dashboard:view','user:manage','org:manage','settings:manage']; %>
            <% allPerms.forEach(p => { %>
              <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-surface-50 dark:hover:bg-surface-700/50 cursor-pointer">
                <input type="checkbox" name="permissions" value="<%= p %>" <%= currentPerms.includes(p) ? 'checked' : '' %> class="rounded border-surface-300 text-primary-600 focus:ring-primary-500">
                <span class="text-sm text-surface-600 dark:text-surface-300"><%= p %></span>
              </label>
            <% }) %>
          </div>
        </div>
        <button type="submit" class="bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">Save Permissions</button>
      </form>
    </div>
  <% }) %>
</div>
