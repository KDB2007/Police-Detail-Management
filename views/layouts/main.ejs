<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PDM Platform - <%= typeof title !== 'undefined' ? title : 'Dashboard' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>[x-cloak] { display: none !important; }</style>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            primary: {'50':'#eff6ff','100':'#dbeafe','200':'#bfdbfe','300':'#93c5fd','400':'#60a5fa','500':'#3b82f6','600':'#2563eb','700':'#1d4ed8','800':'#1e40af','900':'#1e3a8a'},
            surface: {'50':'#f8fafc','100':'#f1f5f9','200':'#e2e8f0','300':'#cbd5e1','400':'#94a3b8','500':'#64748b','600':'#475569','700':'#334155','800':'#1e293b','900':'#0f172a'}
          }
        }
      }
    }
  </script>
</head>
<body class="bg-surface-50 dark:bg-surface-900 text-surface-800 dark:text-surface-100" x-data="{ sidebarOpen: false, darkMode: localStorage.getItem('darkMode') === 'true' }" x-init="() => { if (darkMode) { document.documentElement.classList.add('dark'); document.body.classList.add('dark'); } }">

<% if (typeof user !== 'undefined' && user) { %>
  <%
    const navMap = {
      foreman: [
        { label: 'Dashboard', icon: 'fa-gauge-high', url: '/dashboard' },
        { label: 'My Slips', icon: 'fa-file-lines', url: '/slips' },
        { label: 'Create Slip', icon: 'fa-plus-circle', url: '/slips/create' }
      ],
      arborist: [
        { label: 'Dashboard', icon: 'fa-gauge-high', url: '/dashboard' },
        { label: 'Pending Review', icon: 'fa-clipboard-check', url: '/slips?status=submitted' },
        { label: 'All Slips', icon: 'fa-file-lines', url: '/slips' }
      ],
      billing: [
        { label: 'Dashboard', icon: 'fa-gauge-high', url: '/dashboard' },
        { label: 'Approved Slips', icon: 'fa-check-circle', url: '/slips?status=approved' },
        { label: 'Invoices', icon: 'fa-file-invoice-dollar', url: '/invoices' },
        { label: 'Reports', icon: 'fa-chart-bar', url: '/reports' }
      ],
      detail_admin: [
        { label: 'Dashboard', icon: 'fa-gauge-high', url: '/dashboard' },
        { label: 'Pending Recon', icon: 'fa-scale-balanced', url: '/invoices?status=submitted' },
        { label: 'All Invoices', icon: 'fa-file-invoice-dollar', url: '/invoices' },
        { label: 'Slips', icon: 'fa-file-lines', url: '/slips' },
        { label: 'Audit Log', icon: 'fa-history', url: '/admin/audit' },
        { label: 'Reports', icon: 'fa-chart-bar', url: '/reports' }
      ],
      super_admin: [
        { label: 'Dashboard', icon: 'fa-gauge-high', url: '/dashboard' },
        { label: 'Users', icon: 'fa-users', url: '/admin/users' },
        { label: 'Organizations', icon: 'fa-building', url: '/admin/organizations' },
        { label: 'Slips', icon: 'fa-file-lines', url: '/slips' },
        { label: 'Invoices', icon: 'fa-file-invoice-dollar', url: '/invoices' },
        { label: 'Audit', icon: 'fa-history', url: '/admin/audit' },
        { label: 'Settings', icon: 'fa-gear', url: '/admin/settings' },
        { label: 'Reports', icon: 'fa-chart-bar', url: '/reports' }
      ]
    };
    const navItems = navMap[user.role] || navMap.super_admin;
    const isActive = (url) => currentPath && (currentPath === url || (url !== '/dashboard' && currentPath && currentPath.startsWith(url.split('?')[0])));
  %>

  <!-- Mobile overlay -->
  <div x-show="sidebarOpen" x-cloak class="fixed inset-0 z-40 bg-black/50 lg:hidden" @click="sidebarOpen = false" x-transition:enter="transition-opacity ease-linear duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition-opacity ease-linear duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"></div>

  <!-- Desktop flex container -->
  <div class="lg:flex min-h-screen">
    <!-- Sidebar (mobile: fixed overlay off-screen, desktop: static in-flow) -->
    <aside class="fixed inset-y-0 left-0 z-50 w-64 bg-white dark:bg-surface-800 shadow-xl transform transition-transform duration-200 ease-in-out -translate-x-full lg:relative lg:translate-x-0 lg:shadow-none lg:border-r lg:border-surface-200 dark:border-surface-700 lg:z-0 lg:shrink-0 flex flex-col">
      <div class="flex items-center justify-between h-14 px-4 border-b border-surface-200 dark:border-surface-700 shrink-0">
        <a href="/dashboard" class="flex items-center gap-2.5">
          <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center"><i class="fas fa-shield-halved text-white text-sm"></i></div>
          <div>
            <span class="font-bold text-base text-surface-800 dark:text-white">PDM</span>
            <span class="text-[10px] font-medium text-primary-600 dark:text-primary-400 block leading-tight">Platform</span>
          </div>
        </a>
        <button @click="sidebarOpen = false" class="lg:hidden w-7 h-7 flex items-center justify-center rounded-md text-surface-400 hover:text-surface-600 hover:bg-surface-100 dark:hover:bg-surface-700"><i class="fas fa-times text-sm"></i></button>
      </div>
      <nav class="flex-1 px-2 py-3 space-y-0.5 overflow-y-auto">
        <% navItems.forEach(item => { %>
          <a href="<%= item.url %>" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors <%= isActive(item.url) ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-700 dark:text-primary-300' : 'text-surface-600 dark:text-surface-300 hover:bg-surface-100 dark:hover:bg-surface-700' %>">
            <i class="fas <%= item.icon %> w-5 text-center text-sm <%= isActive(item.url) ? 'text-primary-600' : 'text-surface-400' %>"></i>
            <span><%= item.label %></span>
            <% if (item.url.includes('?')) { %>
              <span class="ml-auto w-1.5 h-1.5 rounded-full bg-primary-500"></span>
            <% } %>
          </a>
        <% }) %>
      </nav>
      <div class="px-2 py-3 border-t border-surface-200 dark:border-surface-700 shrink-0">
        <a href="/notifications" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-surface-600 dark:text-surface-300 hover:bg-surface-100 dark:hover:bg-surface-700 transition-colors">
          <i class="fas fa-bell text-surface-400 w-5 text-center text-sm"></i>
          <span>Notifications</span>
          <% if (typeof unreadNotifCount !== 'undefined' && unreadNotifCount > 0) { %>
            <span class="ml-auto inline-flex items-center justify-center min-w-[20px] h-5 px-1 text-[10px] font-bold text-white bg-red-500 rounded-full"><%= unreadNotifCount > 9 ? '9+' : unreadNotifCount %></span>
          <% } %>
        </a>
        <a href="/logout" class="flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
          <i class="fas fa-right-from-bracket w-5 text-center text-sm"></i>
          <span>Logout</span>
        </a>
      </div>
    </aside>

    <!-- Main content area (flex-1 fills remaining width on desktop) -->
    <div class="flex-1 min-w-0 flex flex-col min-h-screen">
      <!-- Top bar -->
      <header class="sticky top-0 z-30 bg-white dark:bg-surface-800 border-b border-surface-200 dark:border-surface-700">
        <div class="flex items-center justify-between h-14 px-4 lg:px-6">
          <div class="flex items-center gap-3">
            <button @click="sidebarOpen = true" class="lg:hidden w-9 h-9 flex items-center justify-center rounded-lg text-surface-500 hover:text-surface-700 hover:bg-surface-100 dark:hover:bg-surface-700"><i class="fas fa-bars text-lg"></i></button>
            <span class="text-xs font-medium bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 px-2.5 py-1 rounded-full uppercase tracking-wide"><%= user.role.replace('_', ' ') %></span>
          </div>
          <div class="flex items-center gap-1">
            <button @click="darkMode = !darkMode; document.documentElement.classList.toggle('dark'); document.body.classList.toggle('dark'); localStorage.setItem('darkMode', darkMode)" class="w-9 h-9 flex items-center justify-center rounded-lg text-surface-500 hover:text-surface-700 hover:bg-surface-100 dark:hover:bg-surface-700 transition-colors">
              <i class="fas" x-bind:class="darkMode ? 'fa-sun' : 'fa-moon'"></i>
            </button>
            <a href="/notifications" class="relative w-9 h-9 flex items-center justify-center rounded-lg text-surface-500 hover:text-surface-700 hover:bg-surface-100 dark:hover:bg-surface-700 transition-colors">
              <i class="fas fa-bell text-sm"></i>
              <% if (typeof unreadNotifCount !== 'undefined' && unreadNotifCount > 0) { %>
                <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full"></span>
              <% } %>
            </a>
            <div class="relative ml-2" x-data="{ open: false }">
              <button @click="open = !open" @click.outside="open = false" class="flex items-center gap-2.5 pl-3 border-l border-surface-200 dark:border-surface-700 py-1 cursor-pointer">
                <div class="w-7 h-7 bg-primary-600 rounded-full flex items-center justify-center text-white text-xs font-bold"><%= user.full_name.charAt(0).toUpperCase() %></div>
                <div class="hidden sm:block text-left leading-tight">
                  <p class="text-sm font-medium text-surface-700 dark:text-surface-200"><%= user.full_name %></p>
                  <p class="text-[11px] text-surface-400"><%= user.role.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) %></p>
                </div>
                <i class="fas fa-chevron-down text-[10px] text-surface-400 hidden sm:block"></i>
              </button>
              <div x-show="open" x-cloak @click="open = false" class="absolute right-0 top-full mt-1.5 w-56 bg-white dark:bg-surface-800 border border-surface-200 dark:border-surface-700 rounded-xl shadow-xl py-1 z-50">
                <div class="px-3 py-2 text-sm text-surface-700 dark:text-surface-200 border-b border-surface-200 dark:border-surface-700 truncate"><%= user.full_name %><br><span class="text-xs text-surface-400"><%= user.email %></span></div>
                <a href="/logout" class="flex items-center gap-3 px-3 py-2.5 mt-1 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg">
                  <i class="fas fa-right-from-bracket w-5 text-center text-sm"></i>
                  <span>Logout</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </header>

      <!-- Page content -->
      <main class="flex-1 p-4 lg:p-6 overflow-y-auto">
        <%- body %>
      </main>
    </div>
  </div>

<% } else { %>
  <%- body %>
<% } %>

</body>
</html>
