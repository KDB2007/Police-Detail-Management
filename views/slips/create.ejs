<div class="mb-6">
  <a href="/slips" class="text-sm text-primary-600 dark:text-primary-400 hover:underline mb-2 inline-block"><i class="fas fa-arrow-left mr-1"></i>Back to Slips</a>
  <h2 class="text-xl font-bold text-surface-800 dark:text-white">Create Police Detail Slip</h2>
  <p class="text-sm text-surface-500 dark:text-surface-400 mt-0.5">Fill in the details for the police detail slip</p>
</div>

<div class="max-w-3xl">
  <form method="POST" action="/slips/create" enctype="multipart/form-data" class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 p-6 space-y-6">
    <% if (errors && errors.length > 0) { %>
      <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg px-4 py-3">
        <% errors.forEach(e => { %><p class="text-sm text-red-600 dark:text-red-400"><i class="fas fa-circle-exclamation mr-1"></i><%= e %></p><% }) %>
      </div>
    <% } %>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Project <span class="text-red-500">*</span></label>
        <select name="project_id" required class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none">
          <option value="">Select Project</option>
          <% projects.forEach(p => { %>
            <option value="<%= p.id %>" <%= slip && slip.project_id == p.id ? 'selected' : '' %>><%= p.project_number %> — <%= p.name %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Officer Name <span class="text-red-500">*</span></label>
        <input type="text" name="officer_name" required value="<%= slip ? slip.officer_name : '' %>" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none" placeholder="e.g. Officer Roberts">
      </div>
      <div>
        <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Badge Number <span class="text-red-500">*</span></label>
        <input type="text" name="officer_badge" required value="<%= slip ? slip.officer_badge : '' %>" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none" placeholder="e.g. B-1234">
      </div>
      <div>
        <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Department <span class="text-red-500">*</span></label>
        <input type="text" name="officer_department" required value="<%= slip ? slip.officer_department : '' %>" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none" placeholder="e.g. Boston PD">
      </div>
      <div>
        <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Shift Start <span class="text-red-500">*</span></label>
        <input type="datetime-local" name="shift_start" id="shift_start" required value="<%= slip ? slip.shift_start : '' %>" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none" onchange="calcHours()">
      </div>
      <div>
        <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Shift End <span class="text-red-500">*</span></label>
        <input type="datetime-local" name="shift_end" id="shift_end" required value="<%= slip ? slip.shift_end : '' %>" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none" onchange="calcHours()">
      </div>
      <div>
        <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Total Hours <span class="text-red-500">*</span></label>
        <input type="number" step="0.25" name="total_hours" id="total_hours" required value="<%= slip ? slip.total_hours : '' %>" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none bg-surface-100 dark:bg-surface-600" placeholder="Auto-calculated" readonly>
      </div>
      <div>
        <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Rate per Hour ($)</label>
        <input type="number" step="0.01" name="rate_per_hour" value="<%= slip ? slip.rate_per_hour : '85.00' %>" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none" placeholder="85.00">
      </div>
      <div>
        <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Location Details <span class="text-red-500">*</span></label>
        <input type="text" name="location_details" required value="<%= slip ? slip.location_details : '' %>" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none" placeholder="e.g. Main St & First Ave">
      </div>
      <div>
        <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Crew Information</label>
        <input type="text" name="crew_info" value="<%= slip ? slip.crew_info : '' %>" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none" placeholder="e.g. Crew A - 3 workers">
      </div>
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Notes</label>
        <textarea name="notes" rows="3" class="w-full px-3 py-2.5 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none" placeholder="Additional notes..."><%= slip ? slip.notes : '' %></textarea>
      </div>
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-surface-700 dark:text-surface-300 mb-1.5">Attachments</label>
        <input type="file" name="attachments" multiple accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" class="w-full text-sm text-surface-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary-50 dark:file:bg-primary-900/20 file:text-primary-700 dark:file:text-primary-300 hover:file:bg-primary-100 dark:hover:file:bg-primary-900/30 cursor-pointer">
        <p class="text-xs text-surface-400 mt-1">Accepted: PDF, JPG, PNG, DOC (max 10MB each)</p>
      </div>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <button type="submit" class="bg-primary-600 hover:bg-primary-700 text-white font-medium px-6 py-2.5 rounded-lg transition-colors text-sm"><i class="fas fa-save mr-1"></i>Save Draft</button>
      <a href="/slips" class="text-surface-600 dark:text-surface-400 hover:text-surface-800 dark:hover:text-surface-200 px-4 py-2.5 text-sm">Cancel</a>
    </div>
  </form>
</div>

<script>
function calcHours() {
  const start = document.getElementById('shift_start').value;
  const end = document.getElementById('shift_end').value;
  const hoursInput = document.getElementById('total_hours');
  if (start && end) {
    const diff = new Date(end) - new Date(start);
    if (diff > 0) {
      hoursInput.value = (diff / (1000 * 60 * 60)).toFixed(2);
    } else {
      hoursInput.value = '';
    }
  } else {
    hoursInput.value = '';
  }
}
<% if (slip && slip.shift_start && slip.shift_end) { %>
calcHours();
<% } %>
</script>
