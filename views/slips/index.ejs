<div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6">
  <div>
    <h2 class="text-xl font-bold text-surface-800 dark:text-white">Police Detail Slips</h2>
    <p class="text-sm text-surface-500 dark:text-surface-400 mt-0.5">Manage and track all police detail slips</p>
  </div>
  <% if (user.role === 'foreman') { %>
    <a href="/slips/create" class="mt-3 sm:mt-0 bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors inline-flex items-center gap-2"><i class="fas fa-plus"></i>New Slip</a>
  <% } %>
</div>

<!-- Filters -->
<div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 p-4 mb-6">
  <form method="GET" action="/slips" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-3">
    <div>
      <label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">Search</label>
      <div class="relative">
        <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-surface-400 text-xs"></i>
        <input type="text" name="search" value="<%= query.search || '' %>" class="w-full pl-8 pr-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none" placeholder="Slip #, officer, project...">
      </div>
    </div>
    <div>
      <label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">Status</label>
      <select name="status" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none">
        <option value="">All Statuses</option>
        <% ['draft','submitted','approved','rejected','non_billable','changes_requested','invoiced','paid','archived'].forEach(s => { %>
          <option value="<%= s %>" <%= query.status === s ? 'selected' : '' %>><%= s.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">Project</label>
      <select name="project_id" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none">
        <option value="">All Projects</option>
        <% projects.forEach(p => { %>
          <option value="<%= p.id %>" <%= query.project_id == p.id ? 'selected' : '' %>><%= p.project_number %> — <%= p.name %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">From Date</label>
      <input type="date" name="date_from" value="<%= query.date_from || '' %>" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none">
    </div>
    <div>
      <label class="block text-xs font-medium text-surface-500 dark:text-surface-400 mb-1">To Date</label>
      <input type="date" name="date_to" value="<%= query.date_to || '' %>" class="w-full px-3 py-2 border border-surface-300 dark:border-surface-600 rounded-lg bg-white dark:bg-surface-700 text-sm focus:ring-2 focus:ring-primary-500 outline-none">
    </div>
    <div class="flex items-end gap-2">
      <button type="submit" class="flex-1 px-3 py-2 bg-primary-600 hover:bg-primary-700 text-white rounded-lg text-sm transition-colors"><i class="fas fa-filter mr-1"></i>Filter</button>
      <a href="/slips" class="px-3 py-2 bg-surface-200 dark:bg-surface-600 hover:bg-surface-300 dark:hover:bg-surface-500 text-surface-600 dark:text-surface-300 rounded-lg text-sm transition-colors"><i class="fas fa-times"></i></a>
    </div>
  </form>
</div>

<div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-surface-50 dark:bg-surface-800/50 text-left text-xs text-surface-500 dark:text-surface-400 uppercase tracking-wider">
          <th class="px-5 py-3 font-medium">Slip #</th>
          <th class="px-5 py-3 font-medium">Project</th>
          <th class="px-5 py-3 font-medium">Officer</th>
          <th class="px-5 py-3 font-medium">Hours</th>
          <th class="px-5 py-3 font-medium">Status</th>
          <th class="px-5 py-3 font-medium">Foreman</th>
          <th class="px-5 py-3 font-medium">Submitted</th>
          <th class="px-5 py-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-surface-100 dark:divide-surface-700">
        <% if (slips.length === 0) { %>
          <tr><td colspan="8" class="px-5 py-12 text-center text-surface-400"><i class="fas fa-file-lines text-2xl mb-2"></i><p>No slips found</p></td></tr>
        <% } else { %>
          <% slips.forEach(slip => { %>
            <tr class="hover:bg-surface-50 dark:hover:bg-surface-700/30 transition-colors">
              <td class="px-5 py-3.5 font-medium text-surface-800 dark:text-surface-200"><%= slip.slip_number %></td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-300"><%= slip.project_number %></td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-300"><%= slip.officer_name %></td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-300"><%= slip.total_hours %></td>
              <td class="px-5 py-3.5"><span class="badge-<%= slip.status %>"><%= slip.status.replace('_', ' ') %></span></td>
              <td class="px-5 py-3.5 text-surface-600 dark:text-surface-300"><%= slip.foreman_name %></td>
              <td class="px-5 py-3.5 text-surface-500 text-xs"><%= slip.submitted_at ? new Date(slip.submitted_at).toLocaleDateString() : '-' %></td>
              <td class="px-5 py-3.5"><a href="/slips/view/<%= slip.id %>" class="text-primary-600 hover:text-primary-800 dark:text-primary-400 text-xs font-medium"><i class="fas fa-eye mr-1"></i>View</a></td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
