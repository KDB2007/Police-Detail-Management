<h2 class="text-xl font-bold text-surface-800 dark:text-white mb-1">Foreman Dashboard</h2>
<p class="text-sm text-surface-500 dark:text-surface-400 mb-6">Welcome back, <%= user.full_name %>. Here's your overview.</p>

<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
  <% const cards = [
    { label: 'Total Slips', value: stats.total, icon: 'fa-file-lines', color: 'text-blue-600 dark:text-blue-400', bg: 'bg-blue-50 dark:bg-blue-900/20' },
    { label: 'Draft', value: stats.draft, icon: 'fa-pen', color: 'text-gray-600 dark:text-gray-400', bg: 'bg-gray-50 dark:bg-gray-900/20' },
    { label: 'Submitted', value: stats.submitted, icon: 'fa-paper-plane', color: 'text-yellow-600 dark:text-yellow-400', bg: 'bg-yellow-50 dark:bg-yellow-900/20' },
    { label: 'Approved', value: stats.approved, icon: 'fa-check-circle', color: 'text-green-600 dark:text-green-400', bg: 'bg-green-50 dark:bg-green-900/20' },
    { label: 'Issues', value: stats.rejected, icon: 'fa-triangle-exclamation', color: 'text-red-600 dark:text-red-400', bg: 'bg-red-50 dark:bg-red-900/20' },
    { label: 'Invoiced/Paid', value: stats.invoiced, icon: 'fa-sack-dollar', color: 'text-emerald-600 dark:text-emerald-400', bg: 'bg-emerald-50 dark:bg-emerald-900/20' }
  ] %>
  <% cards.forEach(card => { %>
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 p-4 hover:shadow-md transition-shadow">
      <div class="flex items-center justify-between mb-2">
        <span class="text-2xl font-bold text-surface-800 dark:text-white"><%= card.value %></span>
        <div class="w-9 h-9 rounded-lg <%= card.bg %> flex items-center justify-center">
          <i class="fas <%= card.icon %> <%= card.color %>"></i>
        </div>
      </div>
      <p class="text-xs text-surface-500 dark:text-surface-400 font-medium"><%= card.label %></p>
    </div>
  <% }) %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2">
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700">
      <div class="flex items-center justify-between px-5 py-4 border-b border-surface-200 dark:border-surface-700">
        <h3 class="font-semibold text-surface-800 dark:text-white text-sm">Recent Slips</h3>
        <div class="flex gap-2">
          <a href="/slips/create" class="text-xs bg-primary-600 hover:bg-primary-700 text-white px-3 py-1.5 rounded-lg transition-colors"><i class="fas fa-plus mr-1"></i>New Slip</a>
          <a href="/slips" class="text-xs text-primary-600 dark:text-primary-400 hover:underline px-2 py-1.5">View All</a>
        </div>
      </div>
      <div class="p-5">
        <% if (mySlips.length === 0) { %>
          <div class="text-center py-8 text-surface-400 dark:text-surface-500">
            <i class="fas fa-file-lines text-3xl mb-2"></i>
            <p class="text-sm">No slips yet. Create your first police detail slip.</p>
          </div>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-xs text-surface-500 dark:text-surface-400 uppercase tracking-wider">
                  <th class="pb-3 font-medium">Slip #</th>
                  <th class="pb-3 font-medium">Project</th>
                  <th class="pb-3 font-medium">Officer</th>
                  <th class="pb-3 font-medium">Hours</th>
                  <th class="pb-3 font-medium">Status</th>
                  <th class="pb-3 font-medium">Date</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-surface-100 dark:divide-surface-700">
                <% mySlips.forEach(slip => { %>
                  <tr class="hover:bg-surface-50 dark:hover:bg-surface-700/50 cursor-pointer transition-colors" onclick="window.location='/slips/view/<%= slip.id %>'">
                    <td class="py-3 font-medium text-surface-800 dark:text-surface-200"><%= slip.slip_number %></td>
                    <td class="py-3 text-surface-600 dark:text-surface-300"><%= slip.project_number %></td>
                    <td class="py-3 text-surface-600 dark:text-surface-300"><%= slip.officer_name %></td>
                    <td class="py-3 text-surface-600 dark:text-surface-300"><%= slip.total_hours %></td>
                    <td class="py-3"><span class="badge-<%= slip.status %>"><%= slip.status.replace('_', ' ') %></span></td>
                    <td class="py-3 text-surface-500 dark:text-surface-400 text-xs"><%= slip.created_at ? new Date(slip.created_at).toLocaleDateString() : '' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <div>
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 mb-6">
      <div class="px-5 py-4 border-b border-surface-200 dark:border-surface-700">
        <h3 class="font-semibold text-surface-800 dark:text-white text-sm">Active Projects</h3>
      </div>
      <div class="p-5 space-y-3">
        <% if (projects.length === 0) { %>
          <p class="text-sm text-surface-400">No active projects.</p>
        <% } else { %>
          <% projects.slice(0, 5).forEach(p => { %>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-green-500 shrink-0"></div>
              <div class="min-w-0">
                <p class="text-sm font-medium text-surface-700 dark:text-surface-300 truncate"><%= p.project_number %></p>
                <p class="text-xs text-surface-400 truncate"><%= p.name %></p>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700">
      <div class="px-5 py-4 border-b border-surface-200 dark:border-surface-700">
        <h3 class="font-semibold text-surface-800 dark:text-white text-sm">Recent Activity</h3>
      </div>
      <div class="p-5 space-y-3 max-h-64 overflow-y-auto">
        <% if (recentActivity.length === 0) { %>
          <p class="text-sm text-surface-400">No recent activity.</p>
        <% } else { %>
          <% recentActivity.forEach(a => { %>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full bg-surface-100 dark:bg-surface-700 flex items-center justify-center shrink-0 mt-0.5">
                <i class="fas fa-circle text-[8px] text-primary-500"></i>
              </div>
              <div>
                <p class="text-xs text-surface-600 dark:text-surface-300"><span class="font-medium"><%= a.full_name || 'System' %></span> changed status to <span class="badge-<%= a.status %> text-xs"><%= a.status %></span></p>
                <p class="text-xs text-surface-400"><%= new Date(a.created_at).toLocaleString() %></p>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</div>
