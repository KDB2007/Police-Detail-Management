<h2 class="text-xl font-bold text-surface-800 dark:text-white mb-1">Billing Dashboard</h2>
<p class="text-sm text-surface-500 dark:text-surface-400 mb-6">Manage invoices from approved slips.</p>

<div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-6">
  <% const cards = [
    { label: 'Approved Slips', value: approvedCount, icon: 'fa-check-circle', color: 'text-green-600', bg: 'bg-green-50 dark:bg-green-900/20' },
    { label: 'Draft Invoices', value: stats.draft, icon: 'fa-file-pen', color: 'text-gray-600', bg: 'bg-gray-50 dark:bg-gray-900/20' },
    { label: 'Submitted', value: stats.submitted, icon: 'fa-paper-plane', color: 'text-blue-600', bg: 'bg-blue-50 dark:bg-blue-900/20' },
    { label: 'Reconciled', value: stats.reconciled, icon: 'fa-scale-balanced', color: 'text-violet-600', bg: 'bg-violet-50 dark:bg-violet-900/20' },
    { label: 'Paid', value: stats.paid, icon: 'fa-sack-dollar', color: 'text-emerald-600', bg: 'bg-emerald-50 dark:bg-emerald-900/20' }
  ] %>
  <% cards.forEach(card => { %>
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-2xl font-bold text-surface-800 dark:text-white"><%= card.value %></span>
        <div class="w-9 h-9 rounded-lg <%= card.bg %> flex items-center justify-center"><i class="fas <%= card.icon %> <%= card.color %>"></i></div>
      </div>
      <p class="text-xs text-surface-500 dark:text-surface-400 font-medium"><%= card.label %></p>
    </div>
  <% }) %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
  <div class="lg:col-span-2">
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700">
      <div class="px-5 py-4 border-b border-surface-200 dark:border-surface-700 flex items-center justify-between">
        <h3 class="font-semibold text-surface-800 dark:text-white text-sm">Approved Slips Ready for Invoicing</h3>
      </div>
      <div class="p-5">
        <% if (approvedSlips.length === 0) { %>
          <div class="text-center py-8 text-surface-400 dark:text-surface-500">
            <i class="fas fa-check-circle text-3xl mb-2 text-green-400"></i>
            <p class="text-sm">No approved slips waiting for invoicing.</p>
          </div>
        <% } else { %>
          <div class="space-y-3">
            <% approvedSlips.forEach(slip => { %>
              <div class="flex items-center justify-between border border-surface-200 dark:border-surface-700 rounded-lg p-4 hover:bg-surface-50 dark:hover:bg-surface-700/50 transition-colors">
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-medium text-surface-800 dark:text-surface-200"><%= slip.slip_number %> — <%= slip.officer_name %></p>
                  <p class="text-xs text-surface-400"><%= slip.project_number %> • <%= slip.total_hours %> hrs @ $<%= slip.rate_per_hour %>/hr • <span class="badge-approved">Approved</span></p>
                </div>
                <a href="/invoices/redirect-for-slip/<%= slip.id %>" class="shrink-0 text-xs bg-primary-600 hover:bg-primary-700 text-white px-3 py-2 rounded-lg transition-colors ml-3"><i class="fas fa-file-invoice-dollar mr-1"></i>Invoice</a>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <div>
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700">
      <div class="px-5 py-4 border-b border-surface-200 dark:border-surface-700">
        <h3 class="font-semibold text-surface-800 dark:text-white text-sm">Total Billed</h3>
      </div>
      <div class="p-5 text-center">
        <p class="text-3xl font-bold text-primary-600 dark:text-primary-400">$<%= Number(stats.totalBilled).toLocaleString('en-US', {minimumFractionDigits: 2}) %></p>
        <p class="text-xs text-surface-400 mt-1">Lifetime billed amount</p>
      </div>
    </div>
    <div class="bg-white dark:bg-surface-800 rounded-xl border border-surface-200 dark:border-surface-700 mt-4">
      <div class="px-5 py-4 border-b border-surface-200 dark:border-surface-700">
        <h3 class="font-semibold text-surface-800 dark:text-white text-sm">My Invoices</h3>
      </div>
      <div class="p-5 space-y-3 max-h-80 overflow-y-auto">
        <% if (myInvoices.length === 0) { %>
          <p class="text-sm text-surface-400">No invoices yet.</p>
        <% } else { %>
          <% myInvoices.forEach(inv => { %>
            <a href="/invoices/view/<%= inv.id %>" class="flex items-center justify-between p-2 hover:bg-surface-50 dark:hover:bg-surface-700/50 rounded-lg transition-colors">
              <div>
                <p class="text-sm font-medium text-surface-700 dark:text-surface-300"><%= inv.invoice_number %></p>
                <p class="text-xs text-surface-400">$<%= Number(inv.grand_total).toFixed(2) %></p>
              </div>
              <span class="badge-<%= inv.status %> text-xs"><%= inv.status.replace('_', ' ') %></span>
            </a>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>
</div>
