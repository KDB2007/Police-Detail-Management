<div class="min-h-[60vh] flex items-center justify-center">
  <div class="text-center max-w-md">
    <div class="w-16 h-16 bg-red-100 dark:bg-red-900/20 rounded-2xl flex items-center justify-center mx-auto mb-4">
      <i class="fas fa-triangle-exclamation text-red-500 text-2xl"></i>
    </div>
    <h2 class="text-2xl font-bold text-surface-800 dark:text-white mb-2"><%= typeof error !== 'undefined' ? error : 'Error' %></h2>
    <p class="text-surface-500 dark:text-surface-400 mb-6"><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %></p>
    <a href="/dashboard" class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white font-medium px-6 py-2.5 rounded-lg transition-colors text-sm">
      <i class="fas fa-arrow-left"></i> Back to Dashboard
    </a>
  </div>
</div>
