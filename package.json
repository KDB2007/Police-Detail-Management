{
  "name": "police-detail-management",
  "version": "1.0.0",
  "private": true,
  "description": "Police Detail Management Platform - Enterprise Workflow System",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "pm2": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop pdm-platform",
    "pm2:restart": "pm2 restart pdm-platform",
    "seed": "node database/seed.js",
    "reset": "rm -f database/pdm.db && node database/seed.js && node server.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:seed": "docker compose exec pdm node database/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.4",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-session": "^1.18.1",
    "json2csv": "^6.0.0-alpha.2",
    "langfuse": "^3.38.20",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15",
    "pdfkit": "^0.15.0",
    "uuid": "^10.0.0"
  }
}
